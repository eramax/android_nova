package {
    default_applicable_licenses: ["vendor_nova_license"],
}

cc_binary_host {
    name: "nova_ipc_test",
    compile_multilib: "64",
    srcs: ["nova_ipc_test.c"],
    static_libs: ["libnova_ipc"],
    cflags: [
        "-Wall",
        "-Wextra",
        "-Wno-unused-parameter",
        "-D_GNU_SOURCE",
        "-D_POSIX_C_SOURCE=200809L",
    ],
    stl: "none",
}
